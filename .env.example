# Supabase project URL (safe to expose — used by client-side code)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url-here

# Supabase anonymous/public key (safe to expose — used by client-side code)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Supabase service role key (SERVER ONLY — never expose to the browser)
# Get from: Supabase Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Gemini API key (SERVER ONLY)
GEMINI_API_KEY=your-gemini-api-key-here
